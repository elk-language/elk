module Std::Elk::AST
  ##[
    Represents a symbol value pattern eg. `foo: bar`
  ]##
  sealed primitive class SymbolKeyValuePatternNode
    include PatternNode

    init(key: IdentifierNode, value: PatternNode, location: FS::Location = loop; end); end
    def key: IdentifierNode; end
    def value: PatternNode; end
    def location: FS::Location; end
  end
end
