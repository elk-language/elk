module ::Std::Elk::AST
	##[
		All nodes that should be valid in constant lookups
		should implement this interface.
	]##
	mixin ComplexConstantNode
		include LiteralPatternNode,
						TypeNode,
						UsingEntryNode

		def to_ast_complex_const_node: ComplexConstantNode; end

		interface Convertible
			sig to_ast_complex_const_node: ComplexConstantNode
		end
	end
end
