	context "if" ->
		should "return nil when condition is truthy and then is empty" ->
			result := if true; end
			assert! result == nil
		end

		should "return nil when condition is falsy and then is empty" ->
			result := if false; end
			assert! result == nil
		end

		should "execute the then branch" ->
			a := 5
			if a
				a = a + 2
			end
			assert! a == 7
		end

		should "execute the empty else branch" ->
			a := 5
			if false
				a = a * 2
			end
			assert! a == 5
		end

		should "execute the then branch instead of else" ->
			a := 5
			if a
				a = a + 2
			else
				a = 30
			end
			assert! a == 7
		end

		should "execute the else branch instead of then" ->
			a := 5
			if nil
				a = a + 2
			else
				a = 30
			end
			assert! a == 30
		end

		should "be an expression" ->
			a := 5
			b := if a
				"foo"
			else
				5
			end
			assert! b == "foo"
		end

		should "return the left side if the condition is satisfied" ->
			a := 5
			result := ("foo" if a else 5)
			assert! result == "foo"
		end

		should "return the right side if the condition is not satisfied" ->
			a := nil
			result := ("foo" if a else 5)
			assert! result == 5
		end

		should "return nil when condition is not satisfied" ->
			a := nil
			result := ("foo" if a)
			assert! result == nil
		end

		should "access variables defined in the condition" ->
			result := (a + " bar" if a := "foo")
			assert! result == "foo bar"
		end
	end

	context "unless" ->
		should "return nil when condition is falsy and then is empty" ->
			result := (unless false; end)
			assert! result == nil
		end

		should "return nil when condition is truthy and then is empty" ->
			result := (unless true; end)
			assert! result == nil
		end

		should "execute the then branch" ->
			var a: Int? = nil
			b := unless a
				a = 7
			end
			assert! a == 7
		end

		should "execute the empty else branch" ->
			a := 5
			b := unless true
				a = a * 2
			end
			assert! b == nil
		end

		should "execute the then branch instead of else" ->
			var a: Int? = nil
			unless a
				a = 10
			else
				a = a + 2
			end
			assert! a == 10
		end

		should "execute the else branch instead of then" ->
			a := 5
			unless a
				a = 30
			else
				a = a + 2
			end
			assert! a == 7
		end

		should "be an expression" ->
			a := true
			b := unless a
				"foo"
			else
				5
			end
			assert! b == 5
		end

		should "return the left side if the condition is satisfied" ->
			a := nil
			result := ("foo" unless a)
			assert! result == "foo"
		end

		should "return nil if the condition is not satisfied" ->
			a := 5
			result := ("foo" unless a)
			assert! result == nil
		end

		should "can access variables defined in the condition" ->
			result := (a unless a := false)
			assert! result == false
		end
	end

	context "logical or" ->
		should "return right operand if left is nil" ->
			result := (nil || 4)
			assert! result == 4
		end

		should "return right operand (nil) if left is nil" ->
			result := (nil || nil)
			assert! result == nil
		end

		should "return right operand (false) if left is nil" ->
			result := (nil || false)
			assert! result == false
		end

		should "return right operand if left is false" ->
			result := (false || "foo")
			assert! result == "foo"
		end

		should "return left operand if it's truthy" ->
			result := (3 || "foo")
			assert! result == 3
		end

		should "return right nested operand if left are falsy" ->
			result := (false || nil || 4)
			assert! result == 4
		end

		should "return middle nested operand if left is falsy" ->
			result := (false || 2 || 5)
			assert! result == 2
		end
	end

	context "logical and" ->
		should "return left operand if left is nil" ->
			result := (nil && 4)
			assert! result == nil
		end

		should "return left operand if left is false" ->
			result := (false && "foo")
			assert! result == false
		end

		should "return right operand if left is truthy" ->
			result := (3 && "foo")
			assert! result == "foo"
		end

		should "return right operand (false) if left is truthy" ->
			result := (3 && false)
			assert! result == false
		end

		should "return right nested operand if left are truthy" ->
			result := (4 && "bar" && 16)
			assert! result == 16
		end

		should "return middle nested operand if left is truthy" ->
			result := (4 && nil && 5)
			assert! result == nil
		end
	end

	context "nil coalescence" ->
		should "return right operand if left is nil" ->
			result := (nil ?? 4)
			assert! result == 4
		end

		should "return right operand (nil) if left is nil" ->
			result := (nil ?? nil)
			assert! result == nil
		end

		should "return right operand (false) if left is nil" ->
			result := (nil ?? false)
			assert! result == false
		end

		should "return left operand if left is false" ->
			result := (false ?? 'foo')
			assert! result == false
		end

		should "return left operand if it's not nil" ->
			result := (3 ?? 'foo')
			assert! result == 3
		end

		should "return right nested operand if left are nil" ->
			result := (nil ?? nil ?? 4)
			assert! result == 4
		end

		should "return middle nested operand if left is nil" ->
			result := (nil ?? false ?? 5)
			assert! result == false
		end
	end

end
