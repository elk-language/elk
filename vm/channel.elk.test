using Std::Test::Assertions::*
using Std::Test::*
using Std::Sync::WaitGroup
using Std::Sync::WaitGroup::spawn!

describe "Channel", ->

	context "select", ->
		should "trigger the case for available buffered channel", ->
			ch1 := Channel::[Int](5)
			ch2 := Channel::[Int]()

			ch1 << 9

			var result: Int?
			select
			case v := <<ch1
				result = v.unwrap + 3
			case v := <<ch2
				result = v.unwrap * 2
			end

			assert! result == 12
		end

		should "wait and trigger the read case for available channel", ->
			ch1 := Channel::[Int](5)
			ch2 := Channel::[Int](5)

			wg := WaitGroup()

			spawn! wg, go
				sleep 100.milliseconds
				ch1 << 9
			end

			spawn! wg, go
				sleep 10.milliseconds
				ch2 << 3
			end

			var result: Int?
			select
			case v := <<ch1
				result = v.unwrap + 3
			case v := <<ch2
				result = v.unwrap * 2
			end

			wg.wait

			assert! result == 6
		end

		should "wait and trigger the write case for available channel", ->
			ch1 := Channel::[Int]()
			ch2 := Channel::[Int]()

			wg := WaitGroup()

			spawn! wg, go
				sleep 100.milliseconds
				<<ch1
			end

			spawn! wg, go
				sleep 10.milliseconds
				<<ch2
			end

			var result: Int?
			select
			case ch1 << 420
				result = 420
			case ch2 << 69
				result = 69
			end

			ch1 << -1
			wg.wait

			assert! result == 69
		end

		should "trigger default case", ->
			ch1 := Channel::[Int](5)
			ch2 := Channel::[Int](5)

			wg := WaitGroup()

			spawn! wg, go
				sleep 100.milliseconds
				ch1 << 9
			end

			spawn! wg, go
				sleep 10.milliseconds
				ch2 << 3
			end

			var result: Int?
			select
			case v := <<ch1
				result = v.unwrap + 3
			case v := <<ch2
				result = v.unwrap * 2
			else
				result = -420
			end

			wg.wait

			assert! result == -420
		end

		should "trigger send case when no reader is available", ->
			ch1 := Channel::[Int]()
			ch2 := Channel::[Int](5)

			wg := WaitGroup()

			spawn! wg, go
				sleep 10.milliseconds
				<<ch1
			end

			spawn! wg, go
				sleep 100.milliseconds
				ch2 << 3
			end

			var result: Int?
			select
			case ch1 << 9
				result = 69
			case v := <<ch2
				result = v.unwrap * 2
			end

			wg.wait

			assert! result == 69
		end


	end

	context "capacity", ->
		should "return 0 for non-buffered channel", ->
			ch := Channel::[Float]()
			assert! ch.capacity == 0
		end

		should "return non-zero for buffered channel", ->
			ch := Channel::[Float](10)
			assert! ch.capacity == 10
		end
	end

	context "length", ->
		should "return 0 for non-buffered channel", ->
			ch := Channel::[Float]()
			assert! ch.length == 0
		end

		should "return zero for buffered channel with no elements", ->
			ch := Channel::[Float](10)
			assert! ch.length == 0
		end

		should "return non-zero for buffered channel with elements", ->
			ch := Channel::[Float](10)
			assert! ch.length == 0

			ch << 2.0
			assert! ch.length == 1

			ch << 55.2
			assert! ch.length == 2
		end
	end

	context "left_capacity", ->
		should "return 0 for non-buffered channel", ->
			ch := Channel::[Float]()
			assert! ch.left_capacity == 0
		end

		should "return capacity for buffered channel with no elements", ->
			ch := Channel::[Float](10)
			assert! ch.capacity == 10
			assert! ch.left_capacity == 10
		end

		should "return non-zero for buffered channel with elements", ->
			ch := Channel::[Float](10)
			assert! ch.left_capacity == 10

			ch << 2.0
			assert! ch.left_capacity == 9

			ch << 55.2
			assert! ch.left_capacity == 8
		end
	end

	context "==", ->
		should "return true for the same channel object", ->
			ch := Channel::[Float]()
			result := ch == ch
			assert! result == true
		end

		should "return false for different channel", ->
			ch1 := Channel::[Float]()
			ch2 := Channel::[Float]()
			result := ch1 == ch2
			assert! result == false
		end
	end

	context "=~", ->
		should "return true for the same channel object", ->
			ch := Channel::[Float]()
			result := ch =~ ch
			assert! result == true
		end

		should "return false for different channel", ->
			ch1 := Channel::[Float]()
			ch2 := Channel::[Float]()
			result := ch1 =~ ch2
			assert! result == false
		end
	end

	context "push", ->
		should "should push to buffered channel without blocking", ->
			ch := Channel::[Float](2)
			ch << 2.5
		end

		should "should throw when pushing to closed channel", ->
			ch := Channel::[Float](2)
			ch.close
			assert_throws! ch << 2.5 match Channel::ClosedError()
		end
	end

	context "<<@", ->
		should "should pop from a buffered channel without blocking", ->
			ch := Channel::[Float](2)
			ch << 2.5

			result := <<ch
			assert! result.ok == true
			assert! result.unwrap == 2.5
		end

		should "should return an error when popping from a closed channel", ->
			ch := Channel::[Float](2)
			ch.close
			result := <<ch
			assert! result.ok == false
			assert! result.err <<: Channel::ClosedError
		end
	end

	context "pop", ->
		should "should pop from a buffered channel without blocking", ->
			ch := Channel::[Float](2)
			ch << 2.5

			ch.pop
		end

		should "should throw when popping from a closed channel", ->
			ch := Channel::[Float](2)
			ch.close
			assert_throws! ch.pop match Channel::ClosedError()
		end
	end

	context "close", ->
		should "should close an open channel", ->
			ch := Channel::[Float](2)
			ch.close
		end

		should "should throw when closing a closed channel", ->
			ch := Channel::[Float](2)
			ch.close
			assert_throws! ch.close() match Channel::ClosedError()
		end
	end

	context "readonly", ->
		should "should return a read view of channel", ->
			ch := Channel::[Float](2)
			ch << 5.5

			rch := ch.readonly
			assert! rch <<: ReadChannel
			result := <<rch
			assert! result.unwrap == 5.5
		end
	end

	context "writeonly", ->
		should "should return a write view of channel", ->
			ch := Channel::[Float](2)

			wch := ch.writeonly
			assert! wch <<: WriteChannel
			wch << 5.5

			result := <<ch
			assert! result.unwrap == 5.5
		end
	end

	context "iter", ->
		should "should return a read view of channel", ->
			ch := Channel::[Float](3)
			ch << 5.5
			ch << 2.25
			ch.close

			var result: ArrayList[Float] = []
			for f in ch
				result << f
			end

			assert! result == [5.5, 2.25]
		end
	end

end
