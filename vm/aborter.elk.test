using Std::Test::Assertions::*
using Std::Test::*
using Std::Sync::WaitGroup
using Std::Sync::WaitGroup::spawn!

describe "Aborter", ->
	context "singleton", ->
		context "closed", ->
			should "create a closed aborter", ->
				aborter := Aborter.closed
				assert! aborter.is_closed == true
				assert! aborter.is_closable == true
				<<aborter.closed
			end
		end

		context "timeout", ->
			should "create an aborter that gets closed after 10 milliseconds", ->
				aborter := Aborter.timeout(100.milliseconds)
				start := Time.now

				<<aborter.closed
				elapsed := Time.now - start
				assert! elapsed >= 100.milliseconds
			end
		end
	end

	context "instance", ->
	end

end
