using Std::Test::Assertions::*
using Std::Test::*

describe "switch expression", ->
  should "match no value", ->
    var a: Int = 20
    result :=
      switch a
      case 0 then :a
      case 5 then :b
      case 10 then :c
      case 15 then :d
      end
    assert! result == nil
  end

  should "match with variable", ->
    var a: Int = 20
    result :=
      switch a
      case 0 then :a
      case n then n + 2
      case 10 then :c
      case 15 then :d
      end
    assert! result == 22
  end

  should "match no value with else", ->
    var a: any = 20
    result :=
      switch a
      case 0 then :a
      case 5 then :b
      case 10 then :c
      case 15 then :d
      else :e
      end
    assert! result == :e
  end

  should "match boolean", ->
    var a: any = true
    result :=
      switch a
      case 0 then :a
      case false then :b
      case true then :c
      case 15 then :d
      end
    assert! result == :c
  end

  should "match nil", ->
    var a: any = nil
    result :=
      switch a
      case 0 then :a
      case nil then :b
      case true then :c
      case 15 then :d
      end
    assert! result == :b
  end

  should "match string", ->
    var a: any = "some string"
    result :=
      switch a
      case 0 then :a
      case nil then :b
      case "some other string" then :b
      case "some string" then :c
      case 15 then :d
      end
    assert! result == :c
  end

  should "match interpolated string", ->
    var a: any = "some 7 string"
    result :=
      switch a
      case 0 then :a
      case nil then :b
      case "some other string" then :b
      case "some ${5 + 2} string" then :c
      case 15 then :d
      end
    assert! result == :c
  end

  should "match string with regex", ->
    var a: any = "some string"
    result :=
      switch a
      case 0 then :a
      case nil then :b
      case %/^some other string$/ then :b
      case %/some str\w+/ then :c
      case 15 then :d
      end
    assert! result == :c
  end

  should "match string with interpolated regex", ->
    var a: any = "some 7 string"
    result :=
      switch a
      case 0 then :a
      case nil then :b
      case %/^some other string$/ then :b
      case %/some ${2 + 5} str\w+/ then :c
      case 15 then :d
      end
    assert! result == :c
  end

  should "match symbol", ->
    var a: any = :foo
    result :=
      switch a
      case 0 then :a
      case :bar then :b
      case "foo" then :b
      case :foo then :c
      case 15 then :d
      end
    assert! result == :c
  end

  should "match interpolated symbol", ->
    var a: any = :foo7
    result :=
      switch a
      case 0 then :a
      case :bar then :b
      case "foo7" then :b
      case :"foo${2 + 5}" then :c
      case 15 then :d
      end
    assert! result == :c
  end

  should "match with method call", ->
    var a: any = "10"
    result :=
      switch a
      case > 20 then :a
      case > 5 && < 8 then :b
      case > 9 && < 15 then :c
      case == 10.to_string then :d
      case 15 then :e
      end
    assert! result == :d
  end

  should "match comparison with and", ->
    var a: any = 10
    result :=
      switch a
      case > 20 then :a
      case > 5 && < 8 then :b
      case > 9 && < 15 then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match or", ->
    var a: any = "foo"
    result :=
      switch a
      case "bar" || "foo" then :a
      case > 5 && < 8 then :b
      case > 9 && < 15 then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :a
  end

  should "match nilable with a non nil value", ->
    var a: any = "foo"
    result :=
      switch a
      case String()? then :a
      case > 5 && < 8 then :b
      case > 9 && < 15 then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :a
  end

  should "match nilable with nil", ->
    var a: any = nil
    result :=
      switch a
      case String()? then :a
      case > 5 && < 8 then :b
      case > 9 && < 15 then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :a
  end

  should "match non nil value with must", ->
    var a: any = "foo"
    result :=
      switch a
      case must then :a
      else :b
      end
    assert! result == :a
  end

  should "not match nil with must", ->
    var a: any = nil
    result :=
      switch a
      case must then :a
      else :b
      end
    assert! result == :b
  end

  should "match non-list with list patterns", ->
    var a: any = :foo
    result :=
      switch a
      case < 9 then :a
      case [1, 6, 10] then :b
      case [< 2, 6, > 5, 20] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == nil
  end

  should "match tuple with list patterns", ->
    var a: any = %[1, 6, 9, 20]
    result :=
      switch a
      case < 9 then :a
      case [1, 6, 10] then :b
      case [< 2, 6, > 5, 20] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == nil
  end

  should "match set", ->
    var a: any = ^[1, 6, 9, 20]
    result :=
      switch a
      case < 9 then :a
      case ^[1, 6, 10] then :b
      case ^[1, 6, 9, 20] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match word set", ->
    var a: any = ^['foo', 'bar']
    result :=
      switch a
      case < 9 then :a
      case ^['foo', 'ba'] then :b
      case ^w[foo bar] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match symbol set", ->
    var a: any = ^[:foo, :bar]
    result :=
      switch a
      case < 9 then :a
      case ^[:foo, :ba] then :b
      case ^s[foo bar] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match hex set", ->
    var a: any = ^[0xfe, 0x4]
    result :=
      switch a
      case < 9 then :a
      case ^[0xfe, 0x5] then :b
      case ^x[fe 4] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match bin set", ->
    var a: any = ^[0b11, 0b10]
    result :=
      switch a
      case < 9 then :a
      case ^[0b11, 0b01] then :b
      case ^b[11 10] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match empty set", ->
    var a: any = ^[]
    result :=
      switch a
      case < 9 then :a
      case ^[1, 6, 10] then :b
      case ^[] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match set with rest elements", ->
    var a: any = ^[1, 6, 9, 20]
    result :=
      switch a
      case < 9 then :a
      case ^[1, 6, 10] then :b
      case ^[6, 20, 1, *] then :c
      case 15 then :e
      end
    assert! result == :c
  end

  should "match set with skip elements", ->
    var a: any = ^[1, 6, 9, 20]
    result :=
      switch a
      case < 9 then :a
      case ^[1, 6, _] then :b
      case ^[6, 20, 1, _] then :c
      case 15 then :e
      end
    assert! result == :c
  end

  should "match list", ->
    var a: any = [1, 6, 9, 20]
    result :=
      switch a
      case < 9 then :a
      case [1, 6, 10] then :b
      case [< 2, 6, > 5, 20] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match word list", ->
    var a: any = ['foo', 'bar']
    result :=
      switch a
      case < 9 then :a
      case ['foo', 'ba'] then :b
      case \w[foo bar] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match tuple with word list", ->
    var a: any = %['foo', 'bar']
    result :=
      switch a
      case < 9 then :a
      case ['foo', 'ba'] then :b
      case \w[foo bar] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == nil
  end

  should "match symbol list", ->
    var a: any = [:foo, :bar]
    result :=
      switch a
      case < 9 then :a
      case [:foo, :ba] then :b
      case \s[foo bar] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match tuple with symbol list", ->
    var a: any = %[:foo, :bar]
    result :=
      switch a
      case < 9 then :a
      case [:foo, :ba] then :b
      case \s[foo bar] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == nil
  end

  should "match hex list", ->
    var a: any = [0xfe, 0x4]
    result :=
      switch a
      case < 9 then :a
      case [0xfe, 0x5] then :b
      case \x[fe 4] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match tuple with hex list", ->
    var a: any = %[0xfe, 0x4]
    result :=
      switch a
      case < 9 then :a
      case [0xfe, 0x5] then :b
      case \x[fe 4] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == nil
  end

  should "match bin list", ->
    var a: any = [0b11, 0b10]
    result :=
      switch a
      case < 9 then :a
      case [0b11, 0b01] then :b
      case \b[11 10] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match tuple with bin list", ->
    var a: any = %[0b11, 0b10]
    result :=
      switch a
      case < 9 then :a
      case [0b11, 0b01] then :b
      case \b[11 10] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == nil
  end

  should "match empty list", ->
    var a: any = []
    result :=
      switch a
      case < 9 then :a
      case [1, 6, 10] then :b
      case [] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match list with rest elements", ->
    var a: any = [1, 6, 9, 20]
    b :=
      switch a
      case < 9 then :a
      case [1, 6, 10] then :b
      case [< 2, 6, > 5, 2] then :c
      case [1, *a, > 15] then a
      case 15 then :e
      end
    assert! b == [6, 9]
  end

  should "match list with unnamed rest elements", ->
    var a: any = [1, 6, 9, 20]
    result :=
      switch a
      case < 9 then :a
      case [1, 6, 10] then :b
      case [< 2, 6, > 5, 2] then :c
      case [1, *, < 15] then :d
      case [1, *, > 15] then :e
      case 15 then :f
      end
    assert! result == :e
  end

  should "match nested lists", ->
    var a: any = [1, 6, [17, 43, [71, 28]], 20]
    result :=
      switch a
      case < 9 then :a
      case [1, 6, 10] then :b
      case [< 2, 6, [17, 43, [42, 28]], 20] then :c
      case [1, 6, [17, > 40, [71, 28]], > 15] then :d
      case 15 then :e
      end
    assert! result == :d
  end

  should "match non-list with tuple patterns", ->
    var a: any = :foo
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %[< 2, 6, > 5, 20] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == nil
  end

  should "match list with tuple patterns", ->
    var a: any = [1, 6, 9, 20]
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %[< 2, 6, > 5, 20] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match tuple", ->
    var a: any = %[1, 6, 9, 20]
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %[< 2, 6, > 5, 20] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match word tuple", ->
    var a: any = %['foo', 'bar']
    result :=
      switch a
      case < 9 then :a
      case %['foo', 'ba'] then :b
      case %w[foo bar] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match list with word tuple", ->
    var a: any = ['foo', 'bar']
    result :=
      switch a
      case < 9 then :a
      case %['foo', 'ba'] then :b
      case %w[foo bar] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match symbol tuple", ->
    var a: any = %[:foo, :bar]
    result :=
      switch a
      case < 9 then :a
      case %[:foo, :ba] then :b
      case %s[foo bar] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match list with symbol tuple", ->
    var a: any = [:foo, :bar]
    result :=
      switch a
      case < 9 then :a
      case %[:foo, :ba] then :b
      case %s[foo bar] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match hex tuple", ->
    var a: any = %[0xfe, 0x4]
    result :=
      switch a
      case < 9 then :a
      case %[0xfe, 0x5] then :b
      case %x[fe 4] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match list with hex tuple", ->
    var a: any = [0xfe, 0x4]
    result :=
      switch a
      case < 9 then :a
      case %[0xfe, 0x5] then :b
      case %x[fe 4] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match bin tuple", ->
    var a: any = %[0b11, 0b10]
    result :=
      switch a
      case < 9 then :a
      case %[0b11, 0b01] then :b
      case %b[11 10] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match list with bin tuple", ->
    var a: any = [0b11, 0b10]
    result :=
      switch a
      case < 9 then :a
      case %[0b11, 0b01] then :b
      case %b[11 10] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match empty tuple", ->
    var a: any = %[]
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %[] then :c
      case == 10 then :d
      case 15 then :e
      end
    assert! result == :c
  end

  should "match tuple with rest elements", ->
    var a: any = %[1, 6, 9, 20]
    b :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %[< 2, 6, > 5, 2] then :c
      case %[1, *a, > 15] then a
      case 15 then :e
      end
    assert! b == [6, 9]
  end

  should "match tuple with unnamed rest elements", ->
    var a: any = %[1, 6, 9, 20]
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %[< 2, 6, > 5, 2] then :c
      case %[1, *, < 15] then :d
      case %[1, *, > 15] then :e
      case 15 then :f
      end
    assert! result == :e
  end

  should "match nested tuples", ->
    var a: any = %[1, 6, %[17, 43, %[71, 28]], 20]
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %[< 2, 6, %[17, 43, %[42, 28]], 20] then :c
      case %[1, 6, %[17, > 40, %[71, 28]], > 15] then :d
      case 15 then :e
      end
    assert! result == :d
  end

  should "match empty map", ->
    var a: any = {}
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case { 1 => > 2, foo: "baz" || "bar", "baz" => 12.2 } then :c
      case {} then :d
      case 15 then :e
      end
    assert! result == :d
  end

  should "match map", ->
    var a: any = { 1 => 5.5, foo: "bar", "baz" => 12.5 }
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case { 1 => > 2.0, foo: "baz" || "bar", "baz" => 12.2 } then :c
      case { 1 => > 2.0, foo: "baz" || "bar", "baz" => < 13.0 } then :d
      case 15 then :e
      end
    assert! result == :d
  end

  should "match map with record", ->
    var a: any = { 1 => 5.5, foo: "bar", "baz" => 12.5 }
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %{ 1 => > 2.0, foo: "baz" || "bar", "baz" => 12.2 } then :c
      case %{ 1 => > 2.0, foo: "baz" || "bar", "baz" => < 13.0 } then :d
      case 15 then :e
      end
    assert! result == :d
  end

  should "match nested maps", ->
    var a: any = { 1 => 5.5, foo: ["bar", 5, 4, { elo: "mordo" }], "baz" => 12.5 }
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case { 1 => > 2.0, foo: ["baz" || "bar", 5, 4, { eli: "mordo" }], "baz" => < 13.0 } then :c
      case { 1 => > 2.0, foo: ["baz" || "bar", 5, 4, { elo: %/^mord\w+$/ }], "baz" => < 13.0 } then :d
      case 15 then :e
      end
    assert! result == :d
  end

  should "match empty record", ->
    var a: any = %{}
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %{ 1 => > 2, foo: "baz" || "bar", "baz" => 12.2 } then :c
      case %{} then :d
      case 15 then :e
      end
    assert! result == :d
  end

  should "match record", ->
    var a: any = %{ 1 => 5.5, foo: "bar", "baz" => 12.5 }
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %{ 1 => > 2.0, foo: "baz" || "bar", "baz" => 12.2 } then :c
      case %{ 1 => > 2.0, foo: "baz" || "bar", "baz" => < 13.0 } then :d
      case 15 then :e
      end
    assert! result == :d
  end

  should "match record with map", ->
    var a: any = %{ 1 => 5.5, foo: "bar", "baz" => 12.5 }
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case { 1 => > 2, foo: "baz" || "bar", "baz" => 12.2 } then :c
      case { 1 => > 2, foo: "baz" || "bar", "baz" => < 13 } then :d
      case 15 then :e
      end
    assert! result == nil
  end

  should "match nested records", ->
    var a: any = %{ 1 => 5.5, foo: ["bar", 5, 4, %{ elo: "mordo" }], "baz" => 12.5 }
    result :=
      switch a
      case < 9 then :a
      case %[1, 6, 10] then :b
      case %{ 1 => > 2.0, foo: ["baz" || "bar", 5, 4, %{ eli: "mordo" }], "baz" => < 13.0 } then :c
      case %{ 1 => > 2.0, foo: ["baz" || "bar", 5, 4, %{ elo: %/^mord\w+$/ }], "baz" => < 13.0 } then :d
      case 15 then :e
      end
    assert! result == :d
  end

  should "match object", ->
    var a: any = "foo bar"
    res :=
      switch a
      case ::Std::Int() then :a
      case ::Std::String(length: < 4) then :b
      case ::Std::String(uppercase, length: > 3 as l) then [uppercase, l]
      case {} then :d
      case 15 then :e
      end
    assert! res == ["FOO BAR", 7]
  end

  should "match inferred object", ->
    a := "foo bar"
    res :=
      switch a
      case @{length: < 4} then :a
      case @{uppercase, length: > 3 as l} then [uppercase, l]
			else :b
      end
    assert! res == ["FOO BAR", 7]
  end
end